# Copy this file to .env (same folder as docker-compose.yml) and fill in real values.
# Never commit the actual .env file — only this .example is meant to be in git.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_use_a_strong_password
POSTGRES_DB=inventory_db

# Allowed origin(s) for the backend's CORS policy (comma-separated if more than one)
CORS_ORIGINS=http://localhost:3000

# Base URL the frontend will call - baked in at build time
VITE_API_URL=http://localhost:8000
